```{r indices_simple, message=FALSE, warning=FALSE}
# Pull the exact wavelengths we need
bands <- spec_long %>%
filter(Wavelength %in% c(445, 531, 570, 680, 705, 750, 800)) %>%
select(Material, Wavelength, Reflectance) %>%
pivot_wider(names_from = Wavelength, values_from = Reflectance)
# Rename columns to make formulas easier to read
bands <- bands %>%
rename(
R445 = `445`,
R531 = `531`,
R570 = `570`,
R680 = `680`,
R705 = `705`,
R750 = `750`,
R800 = `800`
)
# Calculate indices for each material
indices <- bands %>%
mutate(
PRI   = (R531 - R570) / (R531 + R570),
SIPI  = (R800 - R445) / (R800 - R680),
ND705 = (R750 - R705) / (R750 + R705)
) %>%
select(Material, PRI, SIPI, ND705)
indices
bands <- spec_long %>%
filter(Wavelength %in% c(445, 531, 570, 680, 705, 750, 800)) %>%
select(Material, Wavelength, Reflectance) %>%
pivot_wider(names_from = Wavelength, values_from = Reflectance)
indices <- bands %>%
mutate(
PRI   = (`531` - `570`) / (`531` + `570`),
SIPI  = (`800` - `445`) / (`800` - `680`),
ND705 = (`750` - `705`) / (`750` + `705`)
) %>%
select(Material, PRI, SIPI, ND705)
indices
