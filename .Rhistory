setwd("~/GEM521/Hyperspectral/Labs/Lab5")
library(tidyverse)
spec <- read_csv("~/GEM521/Hyperspectral/Labs/Lab5/Data/spectral_measurements.csv")
knitr::opts_chunk$set(echo = TRUE)
#clean names
spec_clean <- spec %>%
rename_with(~ str_replace_all(.x, "_mean\\.mn$", "")) %>%   # remove suffix
rename_with(~ str_replace_all(.x, "^_\\d+_", "")) %>%       # remove leading "_2_"
rename_with(~ str_replace_all(.x, "_", " "))                # underscores to spaces
View(spec_clean)
names(spec_clean)
ggplot(spec_long, aes(x = Wavelength, y = Reflectance, color = Material)) +
geom_line(linewidth = 1) +
labs(
x = "Wavelength (nm)",
y = "Reflectance",
title = "Figure 1. Averaged spectra for five materials"
) +
theme_minimal() +
theme(legend.title = element_blank())
spec_long <- spec_clean %>%
pivot_longer(
cols = -Wavelength,
names_to = "Material",
values_to = "Reflectance"
)
ggplot(spec_long, aes(x = Wavelength, y = Reflectance, color = Material)) +
